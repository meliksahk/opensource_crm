// backend/prisma/schema.prisma
// Faz 1 — Temel veri modeli: User, Role, Permission + ilişki tabloları + RefreshToken.
// İlişki (join) tabloları açıkça modellenir → ileride ek alan (atayan/tarih) eklenebilir.

generator client {
  provider      = "prisma-client-js"
  // Yerel (native) + Docker alpine (musl/openssl3) hedefleri.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String // bcrypt; düz parola ASLA saklanmaz
  firstName     String
  lastName      String
  isActive      Boolean        @default(true)
  // v2.10 multi-tenancy: kullanıcı bir tenant'a bağlı (null = platform/cross-tenant).
  tenantId      String?
  roles         UserRole[]
  refreshTokens RefreshToken[]
  ownedDeals    Deal[]         @relation("DealOwner")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([email])
  @@index([tenantId])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique // örn: ADMIN, SALES, FINANCE
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  // "kaynak.eylem" biçimi — örn: "deal.create", "invoice.read"
  action      String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
}

// --- İlişki (join) tabloları: many-to-many açık modellenir ---

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String // Refresh token'ın SHA-256 hash'i; ham token saklanmaz
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== Faz 3 — Satış (Deal) & Kanban =====

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  stages    Stage[]
  deals     Deal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stage {
  id         String   @id @default(uuid())
  pipelineId String
  name       String // örn: Yeni, İletişim, Teklif, Kazanıldı, Kaybedildi
  position   Int // sütun sırası
  isWon      Boolean  @default(false)
  isLost     Boolean  @default(false)
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      Deal[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id           String         @id @default(uuid())
  pipelineId   String
  stageId      String
  title        String
  contactName  String?
  email        String?
  phone        String?
  company      String?
  value        Decimal?       @db.Decimal(14, 2) // tahmini değer
  currency     String         @default("TRY")
  // Kanban içi sıralama — kesirli rank (çakışmasız taşıma için)
  rank         Decimal        @db.Decimal(30, 15)
  ownerId      String? // atanan satış temsilcisi
  // v2.1: Deal artık Contact/Company'ye bağlanır (nullable — kademeli geçiş).
  contactId    String?
  companyId    String?
  customFields Json?
  status       DealStatus     @default(OPEN)
  pipeline     Pipeline       @relation(fields: [pipelineId], references: [id])
  stage        Stage          @relation(fields: [stageId], references: [id])
  owner        User?          @relation("DealOwner", fields: [ownerId], references: [id])
  activities   DealActivity[]
  invoices     Invoice[]
  quotes       Quote[]
  // Faz 6 multi-tenancy: nullable (kademeli geçiş). Bağlam aktifse otomatik atanır/filtrelenir.
  tenantId     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime? // soft delete

  @@index([stageId, rank])
  @@index([ownerId])
  @@index([pipelineId, status])
  @@index([tenantId])
  @@index([contactId])
  @@index([companyId])
}

model DealActivity {
  id        String   @id @default(uuid())
  dealId    String
  userId    String
  type      String // NOTE, STAGE_CHANGE, CALL, EMAIL
  payload   Json? // {from, to} vb.
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
}

// ===== Faz 4 — Finans & Fatura =====

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String            @id @default(uuid())
  number        String?           @unique // INV-2026-000123 (issue'da atanır; sıralı, atlamasız)
  dealId        String?
  customerName  String
  customerEmail String?
  status        InvoiceStatus     @default(DRAFT)
  currency      String            @default("TRY")
  subtotal      Decimal           @db.Decimal(14, 2)
  taxRate       Decimal           @db.Decimal(5, 2) // % KDV
  taxAmount     Decimal           @db.Decimal(14, 2)
  total         Decimal           @db.Decimal(14, 2)
  amountPaid    Decimal           @default(0) @db.Decimal(14, 2)
  issuedAt      DateTime?
  dueAt         DateTime?
  deal          Deal?             @relation(fields: [dealId], references: [id])
  lineItems     InvoiceLineItem[]
  payments      Payment[]
  createdById   String
  tenantId      String? // Faz 6 multi-tenancy (nullable, kademeli geçiş)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([dealId])
  @@index([dueAt])
  @@index([tenantId])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id           String   @id @default(uuid())
  invoiceId    String
  amount       Decimal  @db.Decimal(14, 2)
  method       String // BANK, CARD, CASH
  reference    String?
  paidAt       DateTime @default(now())
  recordedById String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// Yıl bazlı sıralı fatura numarası sayacı (atlamasız üretim için).
model InvoiceCounter {
  year       Int @id
  lastNumber Int @default(0)
}

// ===== v2.7 — Ürün & Teklif (CPQ) =====

model Product {
  id          String          @id @default(uuid())
  sku         String?         @unique
  name        String
  description String?
  unitPrice   Decimal         @db.Decimal(14, 2)
  currency    String          @default("TRY")
  taxRate     Decimal         @default(0) @db.Decimal(5, 2) // % varsayılan KDV
  active      Boolean         @default(true)
  tenantId    String?
  deletedAt   DateTime? // soft delete (hard delete yok)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  quoteItems  QuoteLineItem[]

  @@index([active])
  @@index([tenantId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quote {
  id                 String          @id @default(uuid())
  number             String?         @unique // QUO-2026-000123 (send'de atanır)
  dealId             String?
  customerName       String
  customerEmail      String?
  status             QuoteStatus     @default(DRAFT)
  currency           String          @default("TRY")
  subtotal           Decimal         @db.Decimal(14, 2)
  taxRate            Decimal         @db.Decimal(5, 2)
  taxAmount          Decimal         @db.Decimal(14, 2)
  total              Decimal         @db.Decimal(14, 2)
  validUntil         DateTime?
  convertedInvoiceId String?         @unique // dönüştürülen fatura (idempotency)
  deal               Deal?           @relation(fields: [dealId], references: [id])
  lineItems          QuoteLineItem[]
  createdById        String
  tenantId           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status])
  @@index([dealId])
  @@index([tenantId])
}

model QuoteLineItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal  @db.Decimal(14, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
  @@index([productId])
}

// Yıl bazlı sıralı teklif numarası sayacı.
model QuoteCounter {
  year       Int @id
  lastNumber Int @default(0)
}

// ===== Faz 5 — Dış Entegrasyonlar =====

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  DEAD
}

model WebhookSubscription {
  id          String            @id @default(uuid())
  url         String
  events      String[] // ["deal.created","invoice.paid"]
  secret      String // HMAC imza anahtarı (yalnız oluşturmada döner; sonra gizli)
  isActive    Boolean           @default(true)
  createdById String
  createdAt   DateTime          @default(now())
  deliveries  WebhookDelivery[]
}

model WebhookDelivery {
  id             String              @id @default(uuid())
  subscriptionId String
  event          String
  payload        Json
  status         DeliveryStatus      @default(PENDING)
  attempts       Int                 @default(0)
  lastError      String?
  nextRetryAt    DateTime?
  signature      String
  createdAt      DateTime            @default(now())
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([subscriptionId])
}

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  template  String
  status    String // SENT, FAILED, SIMULATED
  error     String?
  createdAt DateTime @default(now())
}

// Gelen webhook idempotency anahtarları (tekrar işleme engeli).
model ProcessedWebhook {
  key       String   @id // source + delivery id
  source    String
  createdAt DateTime @default(now())
}

// ===== Faz 6 — Multi-tenancy =====

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ===== v2.1 — Çekirdek CRM nesneleri: Company & Contact =====

model Company {
  id        String    @id @default(uuid())
  name      String
  domain    String?
  industry  String?
  phone     String?
  website   String?
  ownerId   String?
  tenantId  String? // multi-tenancy (otomatik filtre)
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([name])
}

model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  title     String?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerId   String?
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([tenantId])
  @@index([email])
}

// ===== v2.1c — Nitelenmemiş Lead (Contact+Deal'e dönüştürülür) =====

enum LeadStatus {
  NEW
  WORKING
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

model Lead {
  id                 String     @id @default(uuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  companyName        String?
  source             String? // WEB, REFERRAL, EVENT, ...
  status             LeadStatus @default(NEW)
  ownerId            String?
  tenantId           String?
  convertedContactId String?
  convertedDealId    String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([tenantId])
  @@index([status])
}

// ===== v2.2 — Takvim / Toplantı =====

model Meeting {
  id        String   @id @default(uuid())
  title     String
  startsAt  DateTime
  endsAt    DateTime
  location  String?
  notes     String?
  dealId    String?
  contactId String?
  ownerId   String?
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([startsAt])
  @@index([tenantId])
}

// ===== v2.3 — Otomasyon kuralları =====

model AutomationRule {
  id          String   @id @default(uuid())
  name        String
  trigger     String // 'deal.created' | 'deal.moved' | 'lead.created' | 'invoice.paid' | 'invoice.issued'
  conditions  Json? // { field, equals }
  actions     Json // [{ type, ... }]
  isActive    Boolean  @default(true)
  createdById String?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([trigger, isActive])
  @@index([tenantId])
}

// ===== v2.5 — Özel alanlar (low-code) =====

enum CustomFieldEntity {
  DEAL
  CONTACT
  COMPANY
  LEAD
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
}

model CustomFieldDef {
  id        String            @id @default(uuid())
  entity    CustomFieldEntity
  key       String
  label     String
  type      CustomFieldType
  options   String[]          @default([]) // SELECT için
  required  Boolean           @default(false)
  createdAt DateTime          @default(now())

  @@unique([entity, key])
  @@index([entity])
}

// ===== v2.9 — Platform olgunluk (denetim kaydı) =====

// Değişiklik yapan tüm istekler kaydedilir (append-only; hard delete yok).
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorEmail String?
  action     String // HTTP metodu (POST/PATCH/DELETE)
  entity     String // yol segmenti (deals, invoices, ...)
  entityId   String?
  path       String
  statusCode Int
  tenantId   String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entity, createdAt])
  @@index([createdAt])
}
