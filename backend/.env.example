# backend/.env.example — kopyala: cp .env.example .env, ardından gerçek değerleri doldur.

# --- Veritabanı ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/acik_kaynak_crm?schema=public"

# --- JWT ---
# Access ve Refresh için FARKLI, güçlü, rastgele sırlar (örn: openssl rand -base64 48)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- Parola ---
BCRYPT_COST=12

# --- Uygulama ---
NODE_ENV="development"
PORT=3000

# Virgülle ayrılmış izin verilen origin'ler (CORS allowlist)
CORS_ORIGINS="http://localhost:3001"

# Cookie 'Secure' bayrağı production'da true olmalı (HTTPS).
COOKIE_SECURE=false

# Login rate limit (örn. 60 sn'de 5 deneme)
THROTTLE_TTL=60
THROTTLE_LIMIT=5

# --- Seed (ilk admin kullanıcı) ---
SEED_ADMIN_EMAIL="admin@crm.dev"
SEED_ADMIN_PASSWORD="ChangeMe!2026"

# --- Faz 5: Entegrasyonlar ---
# Mail sürücüsü: simulated (gerçekten göndermez, EmailLog yazar) | smtp
MAIL_DRIVER="simulated"
# Giden webhook'ta özel ağ + http'ye izin (yalnız test/self-host; üretimde false)
WEBHOOK_ALLOW_PRIVATE=false
# Gelen webhook HMAC doğrulama sırrı (boşsa inbound endpoint 400 döner)
INBOUND_WEBHOOK_SECRET=""
