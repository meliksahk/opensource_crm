# .env.example — KÖK (docker compose) ortam değişkenleri.
# Kopyala: cp .env.example .env  → değerleri doldur. .env repoya GİRMEZ.
# (Lokal, docker'sız backend geliştirme için ayrıca backend/.env kullanılır.)

# --- PostgreSQL (db servisi) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=acik_kaynak_crm

# --- Backend runtime (env_file ile container'a yüklenir) ---
# NOT: compose, backend için DATABASE_URL'i otomatik 'db' servisine yönlendirir.
NODE_ENV=production
PORT=3000

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_COST=12

CORS_ORIGINS=http://localhost:3001
COOKIE_SECURE=true

THROTTLE_TTL=60
THROTTLE_LIMIT=5

SEED_ADMIN_EMAIL=admin@crm.dev
SEED_ADMIN_PASSWORD=ChangeMe!2026

# --- Entegrasyonlar (Faz 5) ---
MAIL_DRIVER=simulated
WEBHOOK_ALLOW_PRIVATE=false
INBOUND_WEBHOOK_SECRET=
